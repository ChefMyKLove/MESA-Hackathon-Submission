# MESA Agent Environment — copy to .env.orchestrator / .env.researcher / etc.
# Run `node scripts/keygen.js` to generate unique keys for each agent

AGENT_ROLE=orchestrator
AGENT_KEY=your_32byte_private_key_hex_here
AGENT_PUBKEY=your_compressed_pubkey_hex_here

# Anthropic — for Claude-powered agent intelligence
ANTHROPIC_API_KEY=sk-ant-...

# BSV network
MESSAGEBOX_HOST=https://messagebox.babbage.systems
NETWORK=mainnet

# Relay server (dashboard WebSocket)
RELAY_URL=ws://localhost:4000

# Bidding behavior (specialist agents)
BID_MIN=10
BID_MAX=200
